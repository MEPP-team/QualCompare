<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" Name="window" mc:Ignorable="av" x:Class="CompareMetrics.MainWindow"
        Title="QualCompare" Height="530" Width="620" WindowStyle="SingleBorderWindow" ResizeMode="CanResize" MinWidth="480" MinHeight="440" Closing="Window_Closing">
    <Grid Name="grid" Cursor="Arrow" InputScope="Number" Margin="1,0,1,0" MinHeight="3">
        <Grid.RowDefinitions>
            <RowDefinition Height="256*"/>
            <RowDefinition Height="53*"/>
            <RowDefinition Height="205*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TabControl Name="tabControl" Margin="2,10,2,3" Grid.RowSpan="3">
            <TabItem Name="tabItem" Header="Render">

                <Grid Name="grid1" Cursor="Arrow" InputScope="Number" VerticalAlignment="Stretch" Margin="0,0,0,5" UseLayoutRounding="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="OpenRenderParamsButton" Padding="8,4" Click="OpenRenderParams_Click" ToolTip="Render Parameters" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" VerticalAlignment="Center"/>
                            <!--<TextBlock Text="Parameters"/>-->
                        </StackPanel>
                    </Button>
                    <Grid Name="grid2" Margin="10,25,10,0" RenderTransformOrigin="0,0.5" Panel.ZIndex="-1" MinWidth="250" Grid.RowSpan="3" VerticalAlignment="Top" UseLayoutRounding="False">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Grid.RenderTransform>
                        
                        <Label Name="label" Content="Input Folder" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,0,0,-4"/>
                        <TextBox Name="ObjFilePathTextBox" Margin="0,0,73,0" VerticalAlignment="Top" Height="20" Grid.Row="1" />
                        <Button Name="button" Content="Select" Click="SelectObjFile_Click" Height="20" VerticalAlignment="Center" Grid.Row="1" HorizontalContentAlignment="Center" Padding="1,0,1,1" HorizontalAlignment="Right" Width="68" VerticalContentAlignment="Center"/>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="comboBoxFileSelection" SelectedIndex="0" Padding="6,1,5,3" UseLayoutRounding="False" Grid.Column="1" Margin="15,4,1,4" FontSize="11" Height="18">
                                <ComboBoxItem Content="Everything"/>
                                <ComboBoxItem Content="Source Files"/>
                                <ComboBoxItem Content="Distorted Files"/>
                            </ComboBox>

                            <Label x:Name="Selection_Option" Content="File Selection" Width="105"/>
                        </Grid>

                    </Grid>
                    <Grid Height="40" Margin="10,100,10,0" MinWidth="250" Grid.Row="1">

                        <Label Name="label1" Content="Output Folder" HorizontalAlignment="Left" VerticalAlignment="Top" Width="105"/>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0" HorizontalAlignment="Right">
                            <CheckBox x:Name="AutoOutputCheckBox" IsChecked="True" Content="Auto-fill Output Folder"/>
                        </StackPanel>
                        <TextBox Name="OutputDirTextBox" Margin="0,20,73,0" Height="20" VerticalAlignment="Top"/>
                        <Button Name="button1" Content="Select" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,0,0" Click="SelectOutputDir_Click" Height="20" Width="68"/>

                    </Grid>
                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Top" Grid.ColumnSpan="3" Height="38" Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid HorizontalAlignment="Left" Height="38" VerticalAlignment="Center" Width="105" Margin="10,0,0,0">

                            <Label Name="label2" Content="Number of Views" HorizontalAlignment="Center" VerticalAlignment="Top" Padding="0,5,5,5"/>
                            <TextBox Name="NbViewsTextBox" Margin="0,20,0,0" Height="18" VerticalAlignment="Top" HorizontalAlignment="Left" Width="100" Text="1" PreviewTextInput="NumberInput_PreviewTextInput" FlowDirection="LeftToRight" DataObject.Pasting="NumberInput_Pasting" />
                        </Grid>
                        <Grid HorizontalAlignment="Left" Height="38" VerticalAlignment="Center" Width="105" Margin="130,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="117*"/>
                                <ColumnDefinition Width="19*"/>
                            </Grid.ColumnDefinitions>

                            <Label Name="label6" Content="Method" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,5,5,5"/>
                            <ComboBox Name ="MethodComboBox" Margin="0,20,0,0" FontSize="11" VerticalContentAlignment="Top" HorizontalContentAlignment="Left" FontWeight="Normal" FontStyle="Normal" Padding="6,1,5,3" Grid.ColumnSpan="2" SelectionChanged="MethodComboBox_SelectionChanged">
                                <ComboBoxItem Content="Fibonacci" IsSelected="True" />
                                <ComboBoxItem Content="Circle"/>
                                <ComboBoxItem Content="Polyhedral"/>
                            </ComboBox>
                            <!-- Conteneur pour afficher les champs de saisie dynamiques -->

                        </Grid>
                        <DockPanel Name="DynamicInputsPanel" Grid.Column="3" HorizontalAlignment="Left" >
                            <Grid Name="FibonacciGrid" Margin="10,50,10,10" Visibility="Collapsed"/>
                            <Grid x:Name="PolyhedronGrid" Margin="10,0,10,0" VerticalAlignment="Stretch" HorizontalAlignment="Left" DockPanel.Dock="Left" Visibility="Collapsed">
                                <Label Content="Sélectionnez un polyèdre" Padding="0,5,0,5" />
                                <ComboBox x:Name="PolyhedronComboBox" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,20,0,0" FontSize="11" Padding="6,1,5,3" SelectionChanged="PolyhedronComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Tetraèdre" FontSize="11" IsSelected="True" />
                                    <ComboBoxItem Content="Octaèdre" />
                                    <ComboBoxItem Content="Cube" />
                                    <ComboBoxItem Content="Icosaèdre" />
                                    <ComboBoxItem Content="Dodécaèdre" />
                                </ComboBox>
                            </Grid>

                            <!-- Grille pour la méthode Y fixé -->
                            <Grid x:Name="YFixedGrid" Margin="10,0,10,0" HorizontalAlignment="Left">

                                <Label x:Name="label4" Content="Camera Height" VerticalAlignment="Top" Padding="5,5,5,5" Width="105" HorizontalContentAlignment="Center"/>
                                <Slider x:Name="sliderHeight" VerticalAlignment="Bottom" Minimum="-0.8" Maximum="0.8" AutoToolTipPlacement="TopLeft" AutoToolTipPrecision="1" ValueChanged="sliderHeight_ValueChanged"/>
                            </Grid>
                        </DockPanel>
                    </Grid>

                    <Button x:Name="RenderButton" Content="Render" Margin="10,5,0,6" Click="RenderButton_Click" Width="100" Height="20" Grid.Row="3" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <Button x:Name="StopRenderButton" Content="Stop" Margin="130,5,0,0" Click="StopRenderButton_Click" Width="105" Height="20" Grid.Row="3" VerticalAlignment="Top" IsEnabled="False" HorizontalAlignment="Left"/>
                    <Grid Margin="10,0,10,0" Grid.Row="4">

                        <ProgressBar Name="ProgressBar" VerticalAlignment="Top" Visibility="Visible" ClipToBounds="True" RenderTransformOrigin="0.5,0.5" Height="20"/>

                        <ScrollViewer Margin="0,26,0,0" Visibility="Visible" Name="LogScrollViewer" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Left">
                            <TextBox Name="LogTextBox" IsReadOnly="True" TextWrapping="Wrap" VerticalContentAlignment="Bottom" HorizontalContentAlignment="Left" UseLayoutRounding="False" FlowDirection="LeftToRight"/>
                        </ScrollViewer>
                    </Grid>
                    <Grid HorizontalAlignment="Left" Height="18" Margin="10,5,0,0" Grid.RowSpan="2" VerticalAlignment="Top" Width="448">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Label x:Name="Label_type_object" Content="File Format" Padding="5,0,5,0" HorizontalAlignment="Left"/>
                        <ComboBox x:Name="FormatComboBox" Margin="119,0,0,0" Width="105" Height="18" FontSize="11" SelectedIndex="0" Padding="6,1,5,3" UseLayoutRounding="False">
                            <ComboBoxItem Content="obj"/>
                            <ComboBoxItem Content="ply"/>
                        </ComboBox>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Rendering Queue">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Add current Job" Width="170" Click="QueueCurrentJob_Click"/>
                        <Button Content="Cancel current Job" Width="180" Margin="8,0,0,0" Click="CancelSelectedJob_Click"/>
                        <Button Content="Delete selected Job" Width="190" Margin="8,0,0,0" Click="RemoveSelectedJob_Click"/>
                    </StackPanel>

                    <TabControl x:Name="JobsTabControl"
                    Grid.Row="1"
                    ItemsSource="{Binding Jobs, ElementName=window}">

                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Title}"/>
                                    <TextBlock Text=" - "/>
                                    <TextBlock Text="{Binding State}"/>
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>

                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="{Binding Summary}" Margin="0,0,0,6"/>

                                    <ProgressBar Grid.Row="1" Minimum="0" Maximum="100" Value="{Binding Progress}" Height="18"/>

                                    <CheckBox Grid.Row="2" Content="Fermer l'onglet quand terminé"
                                  IsChecked="{Binding AutoCloseWhenDone}" Margin="0,6,0,0"/>

                                    <TextBox Grid.Row="3" Margin="0,6,0,0"
                                 Text="{Binding LogText}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"/>
                                </Grid>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </Grid>
            </TabItem>
            <TabItem Header="Patchify">
                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        
                        <!-- Sélection métrique -->
                        <RowDefinition Height="Auto"/>
                        <!-- Zone patchify -->
                        <RowDefinition Height="Auto"/>
                        <!-- Progress -->
                        <RowDefinition Height="*"/>
                        <!-- Logs -->
                    </Grid.RowDefinitions>

                    <!-- Sélection métrique (inchangé) -->

                    <!-- Zone patchify (inchangé fonctionnellement) -->
                    <Grid Name="gridImg2Patchify" RenderTransformOrigin="0,0.5" Panel.ZIndex="-1" MinWidth="250" VerticalAlignment="Top" Grid.Row="1" Margin="10,0,10,5">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Grid.RenderTransform>
                        <Button x:Name="OpenPatchifyParamsButton" Margin="6,0,-10,0" Padding="8,4" Click="OpenPatchifyParams_Click" ToolTip="Patchify Parameters" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" VerticalAlignment="Center"/>
                                <!--<TextBlock Text="Parameters" VerticalAlignment="Center"/>-->
                            </StackPanel>
                        </Button>

                        <ComboBox x:Name="patchifySingleOrMultipleComboBox" Grid.Row="1" Margin="0,5,0,5" SelectedIndex="1" HorizontalContentAlignment="Stretch">
                            <ComboBoxItem Content="Single file patchification"/>
                            <ComboBoxItem Content="Multiple files patchification"/>
                        </ComboBox>

                        <Label x:Name="Img2PatchifyLabel" Grid.Row="0" VerticalAlignment="Bottom" HorizontalAlignment="Left" Content="Select image to patchify:" Padding="5,5,5,0" Margin="0,0,0,-5"/>
                        <TextBox x:Name="ImgToPatchifyTextBox" Grid.Row="2" Margin="0,0,73,0" VerticalAlignment="Top" Height="20" Text=""/>
                        <Button x:Name="SelectImageToPatchifyButton1" Grid.Row="2" Content="Select" Click="SelectImageToPatchify_Click" Height="20" VerticalAlignment="Top" Width="68" HorizontalAlignment="Right"/>
                        <Button x:Name="Patchifier" Grid.Row="3" Content="Patchify" HorizontalAlignment="Left" Margin="0,5,0,0" Padding="5,1,5,1" Click="Patchify_Click"/>
                    </Grid>

                    <!-- Progress -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10,8,10,0">
                        <ProgressBar x:Name="PatchifyProgressBar" Height="18" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed" IsIndeterminate="False"/>
                        <TextBlock x:Name="PatchifyProgressText" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Logs -->
                    <GroupBox Grid.Row="3" Header="Logs" Margin="10,8,10,10">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                                <Button x:Name="OpenLogButton" Content="Open log" Click="OpenPatchifyLog_Click" Margin="0,0,6,0"/>
                                <Button x:Name="CopyLogButton" Content="Copy" Click="CopyPatchifyLog_Click" Margin="0,0,6,0"/>
                                <Button x:Name="ClearLogButton" Content="Clear" Click="ClearPatchifyLog_Click"/>
                            </StackPanel>
                            <TextBox x:Name="PatchifyLogTextBox"
                 AcceptsReturn="True" AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 IsReadOnly="True" TextWrapping="NoWrap" FontFamily="Consolas"/>
                        </DockPanel>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="Render Parameters" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Blender -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <!-- Script -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <!-- Temp In -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <!-- Temp Out -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <!-- CSV -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <!-- Ext -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <!-- Up Axis -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <!-- MaxParallelism -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <!-- Prefetch -->
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <!-- Résolution -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <!-- Moteur / TAA -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <!-- Filtre / Masque -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <!-- Lumière -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <!-- PLY -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <!-- Background Color -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <!-- Buttons -->
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>


                        <!-- Blender -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Chemin Blender :" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Grid Grid.Row="0" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="BlenderPathTextBox" Grid.Column="0" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Parcourir…" Click="BrowseBlenderButton_Click"/>
                        </Grid>

                        <!-- Script -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Script de rendu (.py) :" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Grid Grid.Row="2" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RenderScriptPathTextBox" Grid.Column="0" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Parcourir…" Click="BrowseScriptButton_Click"/>
                        </Grid>

                        <!-- Temp In -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Dossier Temp (entrée) :" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Grid Grid.Row="4" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TempInTextBox" Grid.Column="0" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Parcourir…" Click="BrowseTempInButton_Click"/>
                        </Grid>

                        <!-- Temp Out -->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Dossier Temp (sortie) :" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Grid Grid.Row="6" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TempOutTextBox" Grid.Column="0" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Parcourir…" Click="BrowseTempOutButton_Click"/>
                        </Grid>

                        <!-- CSV -->
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="CSV modèles (optionnel) :" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Grid Grid.Row="8" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CsvPathTextBox" Grid.Column="0" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Parcourir…" Click="BrowseCsvButton_Click"/>
                        </Grid>

                        <!-- Ext -->
                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Extension images :" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="ImageExtComboBox" Grid.Row="10" Grid.Column="1" Width="140">
                            <ComboBoxItem Content="png"/>
                            <ComboBoxItem Content="jpg"/>
                        </ComboBox>

                        <!-- Up Axis -->
                        <TextBlock Grid.Row="12" Grid.Column="0" Text="Axe vertical (Up Axis) :" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="UpAxisComboBox" Grid.Row="12" Grid.Column="1" Width="140">
                            <ComboBoxItem Content="X"/>
                            <ComboBoxItem Content="Y"/>
                            <ComboBoxItem Content="Z"/>
                        </ComboBox>

                        <!-- MaxParallelism -->
                        <TextBlock Grid.Row="14" Grid.Column="0" Text="Parallélisme max (0 = auto) :" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="MaxParallelismNumeric" Grid.Row="14" Grid.Column="1" Width="140" PreviewTextInput="NumberInput_PreviewTextInput" DataObject.Pasting="NumberInput_Pasting"/>

                        <!-- Prefetch -->
                        <TextBlock Grid.Row="16" Grid.Column="0" Text="Précharger OBJ+textures sur SSD :" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <CheckBox x:Name="PrefetchCheckBox" Grid.Row="16" Grid.Column="1" VerticalAlignment="Center"/>

                        <!-- Résolution -->
                        <TextBlock Grid.Row="18" Grid.Column="0" Text="Résolution (px) :" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Grid Grid.Row="18" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="X :" HorizontalAlignment="Right" />
                            <TextBox x:Name="ResolutionXNumeric" Grid.Column="2" PreviewTextInput="NumberInput_PreviewTextInput" DataObject.Pasting="NumberInput_Pasting" Width="60" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="Y :" HorizontalAlignment="Right" />
                            <TextBox x:Name="ResolutionYNumeric" Grid.Column="4" PreviewTextInput="NumberInput_PreviewTextInput" DataObject.Pasting="NumberInput_Pasting" Width="60" HorizontalAlignment="Right"/>

                        </Grid>

                        <!-- Moteur / TAA -->
                        <TextBlock Grid.Row="20" Grid.Column="0" Text="Moteur / TAA :" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Grid Grid.Row="20" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="RenderEngineComboBox" Grid.Column="2" Width="140">
                                <ComboBoxItem Content="BLENDER_EEVEE_NEXT"/>
                                <ComboBoxItem Content="BLENDER_WORKBENCH"/>
                                <ComboBoxItem Content="CYCLES"/>
                            </ComboBox>
                            <TextBox x:Name="TaaSamplesNumeric" Grid.Column="4" Margin="8,0,0,0" Width="60" PreviewTextInput="NumberInput_PreviewTextInput" DataObject.Pasting="NumberInput_Pasting" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Filtre / Masque -->
                        <TextBlock Grid.Row="22" Grid.Column="0" Text="Filtre / Masque :" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Grid Grid.Row="22" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FilterSizeNumeric" Grid.Column="2" Width="60" PreviewTextInput="floatInput_PreviewTextInput" DataObject.Pasting="NumberInput_Pasting" HorizontalAlignment="Right"/>
                            <TextBox x:Name="MaskThresholdNumeric" Grid.Column="4" Margin="8,0,0,0" Width="60" PreviewTextInput="NumberInput_PreviewTextInput" DataObject.Pasting="NumberInput_Pasting" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Lumière -->
                        <TextBlock Grid.Row="24" Grid.Column="0" Text="Lumière (E / theta / phi) :" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Grid Grid.Row="24" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="E :" HorizontalAlignment="Right" />
                            <TextBox x:Name="SunEnergyNumeric" Grid.Column="1" Width="60" PreviewTextInput="floatInput_PreviewTextInput" DataObject.Pasting="NumberInput_Pasting" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="2" Text="θ :" HorizontalAlignment="Right" />
                            <TextBox x:Name="SunThetaNumeric" Grid.Column="3" Width="60" PreviewTextInput="floatInput_PreviewTextInput" DataObject.Pasting="NumberInput_Pasting" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="4" Text="φ :" HorizontalAlignment="Right" />
                            <TextBox x:Name="SunPhiNumeric" Grid.Column="5" Width="60" PreviewTextInput="floatInput_PreviewTextInput" DataObject.Pasting="NumberInput_Pasting" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- PLY -->
                        <TextBlock Grid.Row="26" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"><Run Text="PLY (mode / "/><Run Language="fr-fr" Text="multiplier / "/><Run Text="bits) :"/></TextBlock>
                        <Grid Grid.Row="26" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="PlyRenderModeComboBox" Grid.Column="0" Width="140">
                                <ComboBoxItem Content="sphere"/>
                                <ComboBoxItem Content="surface"/>
                                <ComboBoxItem Content="voxel"/>
                                <!-- <ComboBoxItem Content="voxel_volume"/>-->
                            </ComboBox>
                            <TextBox x:Name="VoxelRadiusMultiplierNumeric" Grid.Column="2" Margin="8,0,0,0" Width="60" PreviewTextInput="floatInput_PreviewTextInput" DataObject.Pasting="NumberInput_Pasting" VerticalAlignment="Center" HorizontalAlignment="Right" Visibility="Collapsed"/>
                            <TextBox x:Name="PlyVoxelBitsNumeric" Grid.Column="4" Margin="8,0,0,0" Width="60" PreviewTextInput="NumberInput_PreviewTextInput" DataObject.Pasting="NumberInput_Pasting" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                        <!-- Background color -->
                        <TextBlock Grid.Row="28" Grid.Column="0" Text="Couleur de fond :" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Grid Grid.Row="28" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="BgColorTextBox" Grid.Column="2" Text="#000000" Width="60" HorizontalAlignment="Right"/>
                            <Button Grid.Column="4" Content="Choisir…" Click="ChooseBgColorButton_Click" HorizontalAlignment="Right" Width="60" HorizontalContentAlignment="Center"/>
                        </Grid>
                        <!-- Buttons -->
                        <StackPanel Grid.Row="30" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" >
                            <Button x:Name="ResetSettingsButton" Content="Réinitialiser" Margin="0,0,8,0" Click="ResetSettingsButton_Click"/>
                            <Button x:Name="SaveSettingsButton" Content="Enregistrer" Click="SaveSettingsButton_Click"/>
                        </StackPanel>


                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Quick Compare">
                <Grid >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="259*"/>
                        <ColumnDefinition Width="349*"/>
                    </Grid.ColumnDefinitions>
                </Grid>
            </TabItem>


        </TabControl>
    </Grid>
</Window>
