<Window x:Class="CompareMetrics.PatchifyParametersDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Patchify Parameters"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="CanMinimize"
        WindowStyle="ToolWindow">
    <DockPanel Margin="12">
        <Grid Margin="0,-5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <TextBlock Text="Patch Size" Margin="0,0,8,0" Padding="0,0,0,5"/>
            <TextBox Grid.Column="1" Text="{Binding PatchSize}" MinWidth="75" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="1" Text="Step X" Margin="0,0,8,5"/>
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PatchStepX}" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="2" Text="Step Y" Margin="0,0,8,0" Padding="0,0,0,5"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding PatchStepY}" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="3" Text="Overlap Threshold" Margin="0,0,8,5"/>
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PatchOverlapThreshold}" VerticalAlignment="Center"/>
            <StackPanel Grid.Row="4" Grid.ColumnSpan="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Content="Cancel" Width="75" Margin="0,8,0,0" IsCancel="True"/>
                <Button Content="OK" Width="75" Margin="8,8,0,0" IsDefault="True" Click="Ok_Click"/>
            </StackPanel>
        </Grid>

        <!--<StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,8,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button Content="Cancel" Width="80" Margin="0,8,0,0" IsCancel="True"/>
        </StackPanel>-->
    </DockPanel>
</Window>
